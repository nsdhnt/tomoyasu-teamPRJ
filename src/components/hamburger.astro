<script>
    const hamburger = document.querySelector(".hamburger");
    const nav = document.querySelector(".nav");
    hamburger?.addEventListener("click", () => {
        hamburger?.classList.toggle("open");
        nav?.classList.toggle("open");
        console.log("OK");
    });
</script>
<style>
    .hamburgerWrap {
        height: 80px;
        background-image: linear-gradient(
            to bottom,
            rgba(255, 255, 255, 0) 0%,
            rgba(255, 255, 255, 11) 11%
        );
        position: fixed;
        top: 0;
        right: 0;
    }
    .hamburgerWrap {
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: inherit;
        color: #fff;
        padding: 0 25px;
        margin-right: auto;
        margin-left: auto;
    }
    .hamburger {
        width: 24px;
        height: 64px;
        position: relative;
        appearance: none;
        padding: 0;
        margin: 0;
        /* background-color: rgba(217, 217, 217, 0.5); */
        cursor: pointer;
        z-index: 100;
    }
    .hamburger span,
    .hamburger span::after,
    .hamburger span::before {
        position: absolute;
        display: block;
        content: "";
        width: 100%;
        height: 2px;
        background-color: #000;
        transition: all 0.5s;
    }
    .hamburger span::before {
        top: -8px;
    }
    .hamburger span::after {
        bottom: -8px;
    }
    .hamburger.open span {
        background-color: transparent;
    }
    .hamburger.open span::before {
        top: 0px;
        transform: rotate(45deg);
    }
    .hamburger.open span::after {
        bottom: 0px;
        transform: rotate(-45deg);
    }
    .nav {
        position: fixed;
        width: 100%;
        height: 100vh;
        top: 0;
        right: 0;
        background-color: rgba(255, 255, 255, 0.9);
        transform: translateX(100%);
        transition: 0.3s ease;
        border-top: 1px solid #fff;
    }
    .nav-ul {
        margin-top: 70px;
    }
    .nav-li a {
        display: block;
        font-size: 24px;
        color: #000;
        text-decoration: none;
        padding: 20px 0 20px 24px;
        border-bottom: 2px solid #a3a3a3;
        text-transform: uppercase;
    }
    .nav-li a:hover {
        color: #0f5474;
        background-color: #fff;
    }
    .nav.open {
        right: 0;
        transform: translateX(0);
    }
</style>

<div class="hamburgerWrap">
    <button type="button" class="hamburger">
        <span></span>
    </button>
    <nav class="nav">
        <ul class="nav-ul">
            <li class="nav-li"><a href="#">TOP</a></li>
            <li class="nav-li"><a href="#">NAV</a></li>
            <li class="nav-li"><a href="#">Collection</a></li>
            <li class="nav-li"><a href="#">Arnold</a></li>
            <li class="nav-li"><a href="#">Voltage</a></li>
        </ul>
    </nav>
</div>
